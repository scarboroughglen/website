# Google Cloud Run Environment Variables Template
# Copy this to Cloud Run environment variables or Secret Manager

# ============================================================================
# DATABASE
# ============================================================================
# Use Cloud SQL (PostgreSQL) for production
# Format: postgresql://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL="postgresql://hoa_user:PASSWORD@/hoa_production?host=/cloudsql/PROJECT_ID:us-central1:hoa-db"

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV="production"

# ============================================================================
# STORAGE (Choose one: GCP, AWS, or other S3-compatible)
# ============================================================================

# Option 1: Google Cloud Storage (Recommended for GCP)
STORAGE_PROVIDER="gcp"
S3_ENDPOINT="storage.googleapis.com"
S3_PORT="443"
S3_USE_SSL="true"
S3_REGION="us-central1"
S3_ACCESS_KEY="GOOG1E..."  # From service account key
S3_SECRET_KEY="..."        # From service account key
BUCKET_PREFIX=""           # Optional: prefix for bucket names

# Option 2: AWS S3
# STORAGE_PROVIDER="aws"
# S3_ENDPOINT="s3.amazonaws.com"
# S3_PORT="443"
# S3_USE_SSL="true"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY="AKIA..."
# S3_SECRET_KEY="..."

# ============================================================================
# AI PROVIDERS (Optional - for document description extraction)
# ============================================================================
# Use Secret Manager for these:
# gcloud secrets create openai-api-key --data-file=-
# gcloud secrets create gemini-api-key --data-file=-

OPENAI_API_KEY="sk-..."  # OpenAI API key
GEMINI_API_KEY="AIza..." # Google Gemini API key

# ============================================================================
# EMAIL (Optional - for magic link emails)
# ============================================================================
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT="587"
# SMTP_USER="apikey"
# SMTP_PASS="SG...."
# EMAIL_FROM="noreply@scarboroughglenhoa.com"

# ============================================================================
# PROXY SETTINGS (Usually not needed on Cloud Run)
# ============================================================================
# HTTP_PROXY=""
# HTTPS_PROXY=""
# NO_PROXY="metadata.google.internal,169.254.169.254"

# ============================================================================
# SECURITY
# ============================================================================
# Don't use this in production - Cloud Run handles TLS
# NODE_TLS_REJECT_UNAUTHORIZED="1"

# ============================================================================
# NOTES
# ============================================================================
# 1. Store sensitive values in Google Secret Manager
# 2. Use --set-secrets flag in Cloud Run to inject secrets
# 3. Update cloudbuild.yaml substitutions for non-secret env vars
# 4. For local testing with Cloud SQL: Use Cloud SQL Proxy
