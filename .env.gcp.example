# GCP Cloud Storage Configuration (Production)

# Database
DATABASE_URL="file:/app/data/dev.db"
NODE_ENV=production

# Storage Provider (local, gcp, aws)
STORAGE_PROVIDER=gcp

# GCP Cloud Storage with S3-compatible API
# Generate HMAC keys: https://console.cloud.google.com/storage/settings
GCP_ACCESS_KEY=your-gcp-hmac-access-key
GCP_SECRET_KEY=your-gcp-hmac-secret-key

# Optional: Bucket prefix (e.g., "myproject-" -> myproject-hoa, myproject-condo1)
BUCKET_PREFIX=scarborough-glen-

# GCP Project (if using GCP features beyond storage)
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@scarboroughglen.com

# Security
NODE_TLS_REJECT_UNAUTHORIZED=1
