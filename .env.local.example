# =============================================================================
# HOA Portal — Environment Variables
# =============================================================================
# Copy to .env and fill in values.
# .env is git-ignored. Never commit it.
#
# Variables marked (bashrc) are typically exported in ~/.bashrc and will be
# picked up by Docker Compose automatically without being listed here.
# List them here if you need to override them for this project.
# =============================================================================


# =============================================================================
# DATABASE
# =============================================================================

# SQLite file inside the container — matches the volume mount ./data:/app/data
DATABASE_URL=file:/app/data/dev.db


# =============================================================================
# GOOGLE DRIVE
# =============================================================================

# Service account JSON mounted from credentials/ into the container
# Setup: see GOOGLE_DRIVE_STAGING.md Step 3
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-service-account.json

# Service account email — used in error messages by get-drive-folder-ids.ts
# Get from: gcloud iam service-accounts list --filter="displayName:Drive Sync Service" --format='value(email)'
GOOGLE_SERVICE_ACCOUNT_EMAIL=drive-sync@your-project.iam.gserviceaccount.com

# Parent folder ID for "Scarborough Glen Portal (Auto-Sync)" root folder
# Used by: docker compose exec app npx tsx scripts/get-drive-folder-ids.ts
# Get from Drive URL: https://drive.google.com/drive/folders/THIS_PART
DRIVE_PARENT_FOLDER_ID=your_parent_folder_id

# Subfolder IDs for each section
# Get these by running: make drive-folders (requires DRIVE_PARENT_FOLDER_ID above)
# Or copy from the Drive folder URLs directly
DRIVE_FOLDER_HOA=your_hoa_folder_id
DRIVE_FOLDER_CONDO1=your_condo1_folder_id
DRIVE_FOLDER_CONDO2=your_condo2_folder_id
DRIVE_FOLDER_CONDO3=your_condo3_folder_id
DRIVE_FOLDER_CONDO4=your_condo4_folder_id


# =============================================================================
# S3 / OBJECT STORAGE
# =============================================================================

STORAGE_PROVIDER=local          # local (MinIO) | gcp | aws

# ── Local dev (MinIO) — works out of the box, no changes needed ──────────────
S3_ENDPOINT=minio               # Docker service name resolves inside compose network
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_REGION=us-east-1

# ── Production (GCS) — uncomment and fill in ─────────────────────────────────
# STORAGE_PROVIDER=gcp
# S3_ENDPOINT=storage.googleapis.com   # hostname only — no https://
# S3_PORT=443
# S3_ACCESS_KEY=GOOG1E...              # GCS HMAC key (bashrc: GOOGLE_S3_ACCESS_KEY)
# S3_SECRET_KEY=...                    # GCS HMAC secret (bashrc: GOOGLE_S3_SECRET_KEY)
# S3_USE_SSL=true
# S3_REGION=us-central1

# Optional prefix added to all bucket names
# e.g. BUCKET_PREFIX=dev- → buckets become dev-hoa, dev-condo1, etc.
# Leave empty for no prefix (default)
BUCKET_PREFIX=


# =============================================================================
# AI — DESCRIPTION EXTRACTION
# =============================================================================

# Gemini API key for document description extraction
# Get from: https://aistudio.google.com → Get API key
# (bashrc: GEMINI_API_KEY)
GEMINI_API_KEY=AIza...

# OpenAI — legacy, not used in current setup
# OPENAI_API_KEY=sk-...


# =============================================================================
# FORENSICS PDF MCP
# =============================================================================
# Runs on DGX Spark on the local network — not internet-accessible.
# Must be on the same network as the DGX Spark to use this.
# If not configured, sync falls back to Drive description or filename.

# Base URL of the MCP server
FORENSICS_SERVER_URL=http://dgx-spark-claude:18790

# Key UUID — from: cat ~/.forensics-pdf-mcp/key_id.txt
FORENSICS_KEY_ID=$(cat ~/.forensics-pdf-mcp/key_id.txt)

# Private key — choose one method:
#
# Option A: file path (file mounted from credentials/ directory)
#   Setup: cp ~/.forensics-pdf-mcp/private_key.pem credentials/forensics_private_key.pem
FORENSICS_PRIVATE_KEY_FILE=/app/credentials/forensics_private_key.pem
#
# Option B: inline PEM content (no file mount needed)
# FORENSICS_PRIVATE_KEY=$(cat ~/.forensics-pdf-mcp/private_key.pem)


# =============================================================================
# RUNTIME
# =============================================================================

NODE_ENV=production

# Only set this when behind a corporate proxy with self-signed certificates.
# The Dockerfile sets it conditionally based on HTTP_PROXY — don't set it here
# unless you have a specific reason to override.
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Corporate proxy — normally inherited from shell environment automatically.
# Only needed here if Docker Compose isn't picking them up from your shell.
# http_proxy=http://proxy.example.com:8080
# no_proxy=localhost,127.0.0.1,minio
